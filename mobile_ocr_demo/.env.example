# Optional: Zetic text anonymization endpoint (POST JSON with "text")
EXPO_PUBLIC_ZETIC_ANONYMIZE_URL=https://your-backend.example.com/zetic/anonymize

# Optional: LLM endpoint that receives anonymized text and returns response text
EXPO_PUBLIC_LLM_PIPELINE_URL=https://your-backend.example.com/llm/medication-summary

# Optional: ElevenLabs wrapper endpoint returning audioUrl or audioBase64 JSON
EXPO_PUBLIC_ELEVENLABS_TTS_URL=https://your-backend.example.com/tts/elevenlabs
