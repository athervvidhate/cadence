PORT=8787

# Optional upstream Zetic anonymizer endpoint
ZETIC_UPSTREAM_URL=
ZETIC_API_KEY=

# Optional upstream LLM endpoint
LLM_UPSTREAM_URL=
LLM_API_KEY=

# Optional direct Gemma call (used when LLM_UPSTREAM_URL is empty)
GEMMA_API_KEY=
GEMMA_MODEL=gemma-3-27b-it
GEMMA_BASE_URL=https://generativelanguage.googleapis.com/v1beta
# Min 60–120s for large Gemma models and long anonymized discharge text; 30s often times out.
GEMMA_TIMEOUT_MS=120000
CARE_PLAN_GEMMA_MODEL=gemma-3-27b-it
CARE_PLAN_TIMEOUT_MS=120000
CARE_PLAN_MAX_OUTPUT_TOKENS=4096

# ElevenLabs (required for real TTS)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128
